# Google Drive API Configuration
# Get from: https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# Folder ID for storing duplicate/backup files on Drive
NEXT_PUBLIC_DUPLICATE_FOLDER_ID=your_duplicate_folder_id_here

# Google Sheets API Configuration
# Contains the curriculum and course metadata
NEXT_PUBLIC_GOOGLE_SHEETS_ID=your_sheets_id_here

# Google API Service Account Credentials (JSON)
# Generate from https://console.cloud.google.com/
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account_email@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=your_private_key_here

# Optional: Google OAuth credentials for user authentication
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
